# v34 RunPod environment.
# Load with:
#   source scripts/runpod/runpod.env
#
# This file resolves PROJECT_DIR relative to its own location, so it keeps
# working if you rename the repo folder (for example, v32 -> v33).

__EDSVFH_RUNPOD_ENV_DIR__="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
export PROJECT_DIR="${PROJECT_DIR:-$(cd "${__EDSVFH_RUNPOD_ENV_DIR__}/../.." && pwd)}"
export WORKSPACE_ROOT="${WORKSPACE_ROOT:-$(dirname "${PROJECT_DIR}")}"
export DATA_ROOT="${DATA_ROOT:-${WORKSPACE_ROOT}/data}"
export RAW_ROOT="${RAW_ROOT:-${DATA_ROOT}/raw}"
export CONVERTED_ROOT="${CONVERTED_ROOT:-${DATA_ROOT}/converted}"
export ARTIFACT_ROOT="${ARTIFACT_ROOT:-${WORKSPACE_ROOT}/artifacts}"
export LOG_ROOT="${LOG_ROOT:-${WORKSPACE_ROOT}/logs}"
export CACHE_ROOT="${CACHE_ROOT:-${WORKSPACE_ROOT}/cache}"
export CHECKPOINT_ROOT="${CHECKPOINT_ROOT:-${WORKSPACE_ROOT}/checkpoints}"

# Raw / converted dataset layout.
export DROID_RAW_ROOT="${DROID_RAW_ROOT:-${RAW_ROOT}/droid}"
export DROID_SOURCE="${DROID_SOURCE:-${DROID_RAW_ROOT}/1.0.1}"
export DROID_DEBUG_ROOT="${DROID_DEBUG_ROOT:-${CONVERTED_ROOT}/droid_debug}"
export DROID_CURATED_ROOT="${DROID_CURATED_ROOT:-${CONVERTED_ROOT}/droid_curated}"
export FINO_RAW_ROOT="${FINO_RAW_ROOT:-${RAW_ROOT}/fino}"
export FINO_MANIFEST_PATH="${FINO_MANIFEST_PATH:-${FINO_RAW_ROOT}/fino_manifest.jsonl}"
export FINO_PSEUDO_MANIFEST_PATH="${FINO_PSEUDO_MANIFEST_PATH:-${FINO_RAW_ROOT}/fino_manifest_pseudo_onset.jsonl}"
export FINO_CONVERTED_ROOT="${FINO_CONVERTED_ROOT:-${CONVERTED_ROOT}/fino}"
export DROID_BASELINE_SHARD_DIR="${DROID_BASELINE_SHARD_DIR:-${DROID_CURATED_ROOT}}"
export DROID_SUCCESS_BASELINE_PATH="${DROID_SUCCESS_BASELINE_PATH:-${ARTIFACT_ROOT}/droid_success_baseline.pkl}"
export BASE_BUNDLE="${BASE_BUNDLE:-${ARTIFACT_ROOT}/droid_curated_bundle.pkl}"

# DROID not-successful failure route.
# Default mode uses the prepared RLDS/TFDS folder already downloaded at ${DROID_SOURCE}.
# Set DROID_FAILURE_SOURCE_MODE=raw only if you downloaded raw episode folders.
export DROID_FAILURE_SOURCE_MODE="${DROID_FAILURE_SOURCE_MODE:-rlds}"
export DROID_FAILURE_RLDS_ROOT="${DROID_FAILURE_RLDS_ROOT:-${DROID_SOURCE}}"
export DROID_FAILURE_RLDS_SPLIT="${DROID_FAILURE_RLDS_SPLIT:-train}"
export DROID_FAILURE_SCAN_MAX_EPISODES="${DROID_FAILURE_SCAN_MAX_EPISODES:-}"
export DROID_FAILURE_RAW_ROOT="${DROID_FAILURE_RAW_ROOT:-${RAW_ROOT}/droid_raw/1.0.1}"
export DROID_FAILURE_WORK_ROOT="${DROID_FAILURE_WORK_ROOT:-${RAW_ROOT}/droid_failure}"
export DROID_FAILURE_FRAMES_ROOT="${DROID_FAILURE_FRAMES_ROOT:-${DROID_FAILURE_WORK_ROOT}/frames}"
export DROID_FAILURE_MANIFEST_PATH="${DROID_FAILURE_MANIFEST_PATH:-${DROID_FAILURE_WORK_ROOT}/droid_failure_manifest.jsonl}"
export DROID_FAILURE_PSEUDO_MANIFEST_PATH="${DROID_FAILURE_PSEUDO_MANIFEST_PATH:-${DROID_FAILURE_WORK_ROOT}/droid_failure_manifest_pseudo_onset.jsonl}"
export DROID_FAILURE_CONVERTED_ROOT="${DROID_FAILURE_CONVERTED_ROOT:-${CONVERTED_ROOT}/droid_failure}"
export DROID_FAILURE_BUNDLE="${DROID_FAILURE_BUNDLE:-${ARTIFACT_ROOT}/droid_droid_failure_bundle.pkl}"
export DROID_FAILURE_MAX_EPISODES="${DROID_FAILURE_MAX_EPISODES:-}"
export DROID_FAILURE_MAX_FRAMES_PER_EPISODE="${DROID_FAILURE_MAX_FRAMES_PER_EPISODE:-}"
export DROID_FAILURE_FRAME_STRIDE="${DROID_FAILURE_FRAME_STRIDE:-2}"
export DROID_FAILURE_CAMERA_PREFERENCE="${DROID_FAILURE_CAMERA_PREFERENCE:-exterior_image_1_left,exterior_image_2_left,wrist_image_left,ext1,ext2,wrist}"
export DROID_FAILURE_OVERWRITE_FRAMES="${DROID_FAILURE_OVERWRITE_FRAMES:-0}"
export DROID_FAILURE_UPDATE_SCALER="${DROID_FAILURE_UPDATE_SCALER:-1}"
export DROID_RAW_GCS_PREFIX="${DROID_RAW_GCS_PREFIX:-gs://gresearch/robotics/droid_raw/1.0.1}"
export DROID_FAILURE_MANIFEST_SCAN_CKPT="${DROID_FAILURE_MANIFEST_SCAN_CKPT:-${CHECKPOINT_ROOT}/droid_failure_manifest_scan_ckpt.json}"
export DROID_FAILURE_MANIFEST_SCAN_CKPT_EVERY="${DROID_FAILURE_MANIFEST_SCAN_CKPT_EVERY:-64}"
export DROID_FAILURE_MANIFEST_SCAN_RESUME="${DROID_FAILURE_MANIFEST_SCAN_RESUME:-1}"

# Formal experiments use the HF encoder on GPU.
export USE_HF="${USE_HF:-1}"
export ENCODER="${ENCODER:-siglip2_dinov2}"
export EDSVFH_DEVICE="${EDSVFH_DEVICE:-cuda}"
export EDSVFH_TF_DISABLE_GPU="${EDSVFH_TF_DISABLE_GPU:-1}"
export EDSVFH_HF_LOCAL_ONLY="${EDSVFH_HF_LOCAL_ONLY:-0}"
export CONVERT_ENCODER="${CONVERT_ENCODER:-siglip2_dinov2}"
export CONVERT_DEVICE="${CONVERT_DEVICE:-cuda}"
export CONVERT_BATCH_SIZE="${CONVERT_BATCH_SIZE:-16}"
export EDSVFH_DISABLE_CUDNN="${EDSVFH_DISABLE_CUDNN:-0}"

# Main experiment defaults.
# Leave limits empty for the formal paid run.
# The dedicated smoke-test script will override these with small values.
export MAX_EPISODES="${MAX_EPISODES:-}"
export EPISODES_PER_SHARD="${EPISODES_PER_SHARD:-64}"
export IMAGE_SIZE="${IMAGE_SIZE:-96}"
export STEP_STRIDE="${STEP_STRIDE:-2}"
export ACTION_SPACE="${ACTION_SPACE:-raw_action}"
export DROID_OUTCOME_FILTER="${DROID_OUTCOME_FILTER:-success}"

export USE_PSEUDO_ONSET="${USE_PSEUDO_ONSET:-1}"
export EPOCHS="${EPOCHS:-3}"
export FINO_UPDATE_SCALER="${FINO_UPDATE_SCALER:-1}"
export HORIZONS="${HORIZONS:-1,3,5}"
export EDSVFH_HORIZONS="${EDSVFH_HORIZONS:-1,3,5}"
export PSEUDO_ONSET_FEATURE_SOURCE="${PSEUDO_ONSET_FEATURE_SOURCE:-visual}"
export PSEUDO_ONSET_WINDOW="${PSEUDO_ONSET_WINDOW:-3}"
export PSEUDO_ONSET_PHASE_BINS="${PSEUDO_ONSET_PHASE_BINS:-10}"
export PSEUDO_ONSET_QUANTILE="${PSEUDO_ONSET_QUANTILE:-0.97}"
export PSEUDO_ONSET_MIN_PHASE_COUNT="${PSEUDO_ONSET_MIN_PHASE_COUNT:-8}"
export PSEUDO_ONSET_FIT_MAX_EPISODES="${PSEUDO_ONSET_FIT_MAX_EPISODES:-}"

# Larger-horizon diagnostic experiment.
export LARGER_HORIZONS="${LARGER_HORIZONS:-1,3,5,10,15,30,45,60}"
export LARGER_HORIZONS_BASE_BUNDLE="${LARGER_HORIZONS_BASE_BUNDLE:-${DROID_FAILURE_BUNDLE}}"
export LARGER_HORIZONS_FREEZE_EXISTING="${LARGER_HORIZONS_FREEZE_EXISTING:-1}"
export LARGER_HORIZONS_EPOCHS="${LARGER_HORIZONS_EPOCHS:-3}"
export LARGER_HORIZONS_UPDATE_SCALER="${LARGER_HORIZONS_UPDATE_SCALER:-0}"
export LARGER_HORIZONS_RESUME="${LARGER_HORIZONS_RESUME:-0}"
export LARGER_HORIZONS_OUTPUT_BUNDLE="${LARGER_HORIZONS_OUTPUT_BUNDLE:-${ARTIFACT_ROOT}/droid_droid_failure_bundle_horizons_1x3x5x10x15x30x45x60.pkl}"
export LARGER_HORIZONS_CKPT="${LARGER_HORIZONS_CKPT:-${CHECKPOINT_ROOT}/droid_failure_larger_horizons_1x3x5x10x15x30x45x60_ckpt.pkl}"
export LARGER_HORIZONS_LOG="${LARGER_HORIZONS_LOG:-${LOG_ROOT}/test_droid_failure_larger_horizons_1x3x5x10x15x30x45x60.log}"

# DROID failure logs/checkpoints.
export DROID_FAILURE_MANIFEST_LOG="${DROID_FAILURE_MANIFEST_LOG:-${LOG_ROOT}/droid_failure_manifest.log}"
export DROID_FAILURE_PSEUDO_LABEL_LOG="${DROID_FAILURE_PSEUDO_LABEL_LOG:-${LOG_ROOT}/label_droid_failure_pseudo_onset.log}"
export DROID_FAILURE_CONVERT_LOG="${DROID_FAILURE_CONVERT_LOG:-${LOG_ROOT}/convert_droid_failure.log}"
export DROID_FAILURE_TRAIN_LOG="${DROID_FAILURE_TRAIN_LOG:-${LOG_ROOT}/droid_failure_finetune.log}"
export DROID_FAILURE_PSEUDO_PIPELINE_LOG="${DROID_FAILURE_PSEUDO_PIPELINE_LOG:-${LOG_ROOT}/droid_failure_pseudo_onset_pipeline.log}"
export DROID_FAILURE_PSEUDO_CKPT="${DROID_FAILURE_PSEUDO_CKPT:-${CHECKPOINT_ROOT}/droid_failure_pseudo_onset_ckpt.json}"
export DROID_FAILURE_CONVERT_CKPT="${DROID_FAILURE_CONVERT_CKPT:-${CHECKPOINT_ROOT}/droid_failure_convert_ckpt.json}"
export DROID_FAILURE_CKPT="${DROID_FAILURE_CKPT:-${CHECKPOINT_ROOT}/droid_failure_finetune_ckpt.pkl}"

# Legacy FINO variables are kept only for backward-compatible scripts.
export FINO_MANIFEST_CKPT="${FINO_MANIFEST_CKPT:-${CHECKPOINT_ROOT}/fino_manifest_ckpt.json}"
export DROID_DEBUG_CKPT="${DROID_DEBUG_CKPT:-${CHECKPOINT_ROOT}/droid_debug_train_ckpt.pkl}"
export DROID_CURATED_CKPT="${DROID_CURATED_CKPT:-${CHECKPOINT_ROOT}/droid_curated_train_ckpt.pkl}"
export FINO_PSEUDO_CKPT="${FINO_PSEUDO_CKPT:-${CHECKPOINT_ROOT}/fino_pseudo_onset_ckpt.json}"
export FINO_CONVERT_CKPT="${FINO_CONVERT_CKPT:-${CHECKPOINT_ROOT}/fino_convert_ckpt.json}"
export FINO_CKPT="${FINO_CKPT:-${CHECKPOINT_ROOT}/fino_finetune_ckpt.pkl}"
export CONVERT_DROID_CURATED_LOG="${CONVERT_DROID_CURATED_LOG:-${LOG_ROOT}/convert_droid_curated.log}"
export TRAIN_DROID_CURATED_LOG="${TRAIN_DROID_CURATED_LOG:-${LOG_ROOT}/train_droid_curated.log}"
export FINO_TRAIN_LOG="${FINO_TRAIN_LOG:-${LOG_ROOT}/fino_finetune.log}"
export FINO_PSEUDO_PIPELINE_LOG="${FINO_PSEUDO_PIPELINE_LOG:-${LOG_ROOT}/fino_pseudo_onset_pipeline.log}"
export FINO_MANIFEST_LOG="${FINO_MANIFEST_LOG:-${LOG_ROOT}/fino_manifest.log}"
export DROID_SUCCESS_BASELINE_LOG="${DROID_SUCCESS_BASELINE_LOG:-${LOG_ROOT}/fit_droid_success_baseline.log}"
export FINO_PSEUDO_LABEL_LOG="${FINO_PSEUDO_LABEL_LOG:-${LOG_ROOT}/label_fino_pseudo_onset.log}"
export FINO_CONVERT_LOG="${FINO_CONVERT_LOG:-${LOG_ROOT}/convert_fino.log}"
export BG_STATE_ROOT="${BG_STATE_ROOT:-${LOG_ROOT}/bg_state}"
export PAPER_PACK_OUTPUT_ROOT="${PAPER_PACK_OUTPUT_ROOT:-${WORKSPACE_ROOT}}"
export PAPER_PACK_PREFIX="${PAPER_PACK_PREFIX:-paper_pack}"
export PAPER_PACK_LOG="${PAPER_PACK_LOG:-${LOG_ROOT}/paper_pack_results.log}"
export PAPER_PACK_INCLUDE_FULL="${PAPER_PACK_INCLUDE_FULL:-1}"
export PAPER_PACK_INCLUDE_RAW_ENV="${PAPER_PACK_INCLUDE_RAW_ENV:-0}"
export PAPER_PACK_SKIP_EVAL="${PAPER_PACK_SKIP_EVAL:-0}"
export PAPER_PACK_HEAD_LINES="${PAPER_PACK_HEAD_LINES:-20}"
export PAPER_PACK_TOPK_CHANGED="${PAPER_PACK_TOPK_CHANGED:-30}"

# Offline replay and lightweight ablation outputs (DROID failure route).
export REPLAY_BUNDLE="${REPLAY_BUNDLE:-${LARGER_HORIZONS_OUTPUT_BUNDLE}}"
export REPLAY_FIXED_RATES="${REPLAY_FIXED_RATES:-1,3,5,10,15,30,45,60}"
export REPLAY_ALARM_DECISIONS="${REPLAY_ALARM_DECISIONS:-watch,shield,abstain}"
export REPLAY_STOP_ON_TERMINAL="${REPLAY_STOP_ON_TERMINAL:-1}"
export REPLAY_MAX_EPISODES="${REPLAY_MAX_EPISODES:-}"
export REPLAY_OUTPUT_JSON="${REPLAY_OUTPUT_JSON:-${LOG_ROOT}/replay_protocol_metrics.json}"
export REPLAY_OUTPUT_CSV="${REPLAY_OUTPUT_CSV:-${LOG_ROOT}/replay_protocol_metrics.csv}"
export REPLAY_LOG="${REPLAY_LOG:-${LOG_ROOT}/replay_protocol_eval.log}"

export ABLATION_BUNDLES="${ABLATION_BUNDLES:-main=${DROID_FAILURE_BUNDLE},extended=${LARGER_HORIZONS_OUTPUT_BUNDLE}}"
export ABLATION_VARIANTS="${ABLATION_VARIANTS:-calibrated_monotonic,calibrated,raw_monotonic,raw}"
export ABLATION_ECE_BINS="${ABLATION_ECE_BINS:-10}"
export ABLATION_OUTPUT_JSON="${ABLATION_OUTPUT_JSON:-${LOG_ROOT}/ablation_suite_metrics.json}"
export ABLATION_OUTPUT_CSV="${ABLATION_OUTPUT_CSV:-${LOG_ROOT}/ablation_suite_metrics.csv}"
export ABLATION_LOG="${ABLATION_LOG:-${LOG_ROOT}/ablation_suite_eval.log}"

# Cheap validation before a paid full rerun.
export CANARY_PSEUDO_ONSET_FIT_MAX_EPISODES="${CANARY_PSEUDO_ONSET_FIT_MAX_EPISODES:-256}"
export CANARY_EPOCHS="${CANARY_EPOCHS:-1}"
export CANARY_RUN_TARGETED_TESTS="${CANARY_RUN_TARGETED_TESTS:-1}"
export CANARY_RUN_PIPELINE="${CANARY_RUN_PIPELINE:-1}"
export CANARY_STRICT="${CANARY_STRICT:-1}"
export CANARY_LOG="${CANARY_LOG:-${LOG_ROOT}/validate_clean_rerun_canary.log}"
export CANARY_SUMMARY_JSON="${CANARY_SUMMARY_JSON:-${LOG_ROOT}/clean_rerun_canary_summary.json}"
export CANARY_SUMMARY_TXT="${CANARY_SUMMARY_TXT:-${LOG_ROOT}/clean_rerun_canary_summary.txt}"

# Set to 1 to force steps to rerun even when output artifacts already exist.
export EDSVFH_FORCE_RERUN="${EDSVFH_FORCE_RERUN:-0}"

unset __EDSVFH_RUNPOD_ENV_DIR__
